# Firebase web app configuration.
# Copy this file to `.env.local` and fill in values from your Firebase project
# (Project settings -> General -> Your apps -> SDK setup and configuration).
#
# All values are exposed to the client bundle (Vite only inlines VITE_* vars).
# These are NOT secrets — Firebase web config is safe to ship to the browser.
# Real security is enforced via Firestore Security Rules and Auth settings.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# OpenID Connect provider id configured in the Firebase console for Discord.
# Create an OIDC provider in Authentication -> Sign-in method and use its id
# here (the Firebase console prefixes custom OIDC ids with "oidc.").
VITE_DISCORD_OIDC_PROVIDER_ID=oidc.discord

# OpenFront.io API Endpoint for stats ingestion
VITE_OPENFRONT_API_URL=https://api.openfront.io/v1
